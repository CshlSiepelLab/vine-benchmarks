BootStrap: docker
From: python:3.10-slim

%labels
    Description "Python 3.10 and LAML v1.0.5 with some bash commands installed."

%files
    laml.def /opt/laml/laml.def

    # Need active (not expired) Mosek license for LAML
    ~/bin/mosek.lic /opt/build/mosek.lic

%post
    set -eux

    apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        build-essential \
        less \
        vim \
        nano \
        procps \
        wget \
        curl \
        ca-certificates \
        time && \
        rm -rf /var/lib/apt/lists/*

    # Install Cassiopeia
    pip install laml==1.0.5
    pip install scikit-bio

%environment
    export PATH="/usr/local/bin:$PATH"
    export MOSEKLM_LICENSE_FILE="/opt/build/mosek.lic"

%runscript
    exec "$@"





